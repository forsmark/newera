{
  "name": "new-era",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "src/server",
    "src/client"
  ],
  "scripts": {
    "build": "bun run --cwd src/client build",
    "dev:client": "bun run --cwd src/client dev",
    "dev:server": "bun --watch run src/server/index.ts",
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "start": "bun run src/server/index.ts",
    "db:reset": "rm -f db/jobs.db && echo 'Database reset.'",
    "test": "DB_PATH=:memory: bun test src/server",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1"
  }
}
